# Railway backend environment variables
# Set these in Railway dashboard → Variables

SUPABASE_URL=https://nexoykgaeodfvkzfvqmf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Roboflow API key for real jersey detection
# Without this, the scanner uses mock detections
ROBOFLOW_API_KEY=your-roboflow-api-key

# Volume mount paths (Railway volumes)
UPLOAD_DIR=/uploads
CLIPS_DIR=/clips

# Port (Railway sets this automatically)
PORT=3001
